{
    "name": "backend",
    "version": "1.0.0",
    "main": "app.js",
    "type": "module",
    "scripts": {
        "test": "jest --coverage",
        "dev": "nodemon server.js",
        "start": "node server.js",
        "worker": "node worker/evaluationWorker.js",
        "test:watch": "jest --watch",
        "lint": "eslint . --ext .js",
        "lint:fix": "eslint . --ext .js --fix",
        "format": "prettier --write .",
        "build": "echo 'No build step required for Node.js'",
        "seed": "node scripts/seedDatabase.js",
        "migrate": "node scripts/migrate.js",
        "docker:build": "docker build -t contest-api .",
        "docker:run": "docker run -p 5000:5000 contest-api",
        "docker:start": "docker start my-redis redis-commander",
        "docker:stop": "docker stop my-redis redis-commander",
        "pm2:start": "pm2 start ecosystem.config.js",
        "pm2:stop": "pm2 stop ecosystem.config.js",
        "pm2:restart": "pm2 restart ecosystem.config.js",
        "healthcheck": "curl -f http://localhost:5000/health || exit 1"
    },
    "keywords": [
        "contest",
        "management",
        "api",
        "express",
        "mongodb",
        "redis",
        "quiz",
        "competition"
    ],
    "author": "Austin Makasare",
    "license": "ISC",
    "description": "",
    "dependencies": {
        "bull": "^4.16.5",
        "bullmq": "^5.58.0",
        "compression": "^1.8.1",
        "cors": "^2.8.5",
        "dotenv": "^17.2.1",
        "express": "^5.1.0",
        "express-rate-limit": "^8.0.1",
        "helmet": "^8.1.0",
        "json2csv": "^6.0.0-alpha.2",
        "jsonwebtoken": "^9.0.2",
        "libphonenumber-js": "^1.12.13",
        "mongoose": "^8.17.0",
        "morgan": "^1.10.1",
        "node-cron": "^4.2.1",
        "otp-generator": "^4.0.1",
        "pdfkit": "^0.17.1",
        "rate-limit-redis": "^4.2.2",
        "redis": "^5.8.0",
        "slugify": "^1.6.6",
        "socket.io": "^4.8.1",
        "winston": "^3.17.0",
        "winston-daily-rotate-file": "^5.0.0",
        "zod": "^4.0.17"
    },
    "devDependencies": {
        "@types/jest": "^29.5.11",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-node": "^11.1.0",
        "jest": "^29.7.0",
        "mongodb-memory-server": "^9.1.3",
        "nodemon": "^3.1.10",
        "prettier": "^3.1.1",
        "redis-memory-server": "^0.7.0",
        "supertest": "^6.3.3"
    },
    "engines": {
        "node": ">=18.0.0",
        "npm": ">=8.0.0"
    }
}
